/*
 * Update bus/pins for your board before building.
 * This is a starter SSD1306 node example.
 */

&i2c1 {
    status = "okay";

    oled@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <64>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <63>;
        prechargep = <0x22>;
    };
};
